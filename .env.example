# ============================================================
# NIWA Map Agent — environment settings
# Copy this file to ".env.local" and fill in the real values.
# NEVER commit ".env.local" — it holds your secret keys.
# ============================================================

# --- Database (Netlify DB / Neon Postgres connection string) ---
# Get this from your Netlify dashboard: Project > Storage > (Neon) > Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Login security ---
# A long random secret used to sign login sessions.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# --- AI: Groq (image / vision) ---
GROQ_API_KEY=""
GROQ_VISION_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# --- AI: OpenRouter (reasoning / writing) ---
OPENROUTER_API_KEY=""
OPENROUTER_REASONING_MODEL="openai/gpt-oss-120b"

# Optional: shown on OpenRouter usage dashboard
OPENROUTER_SITE_URL="https://niwa-map-agent.netlify.app"
OPENROUTER_APP_NAME="NIWA Map Agent"
